{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "python": {
      "command": ["nix", "develop", "-c", "basedpyright-langserver", "--stdio"],
      "extensions": [".py"]
    },
    "csharp": {
      "command": ["csharp-ls"],
      "extensions": [".cs"]
    }
  },
  "permission": {
    "lsp": "allow"
  },
  "plugin": ["@dietrichgebert/ponytail"]
}
